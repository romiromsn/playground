{
    "name": "cakehx/cakehx",
    "description": "htmx-inspired AJAX plugin for CakePHP 5.x — partial page updates via HTML attributes",
    "type": "cakephp-plugin",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "cakephp/cakephp": "^5.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "CakeHx\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CakeHx\\Test\\": "tests/"
        }
    }
}
